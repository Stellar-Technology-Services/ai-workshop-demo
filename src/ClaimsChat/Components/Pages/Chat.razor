@page "/chat"
@using ClaimsChat.Services.SealedBox
@using Markdig
@inject IGroundedChatService ChatService

<PageTitle>Chat — ClaimsChat</PageTitle>

<h1>Chat</h1>

<p class="muted">
    Ask a question about the claim documents. Lexical retrieval selects the most relevant
    passages, the model answers from them, and the answer streams back with its sources.
</p>

<div class="chat-log">
    @foreach (var entry in _entries)
    {
        <div class="chat-msg @(entry.IsUser ? "user" : "assistant")">
            <strong>@(entry.IsUser ? "You" : "Assistant"):</strong>
            @if (entry.IsUser || entry.IsError)
            {
                <span class="@(entry.IsError ? "chat-error" : null)">@entry.Text</span>
            }
            else if (entry.IsStreaming)
            {
                @* While streaming, show raw text (whitespace preserved). Markdown is
                   parsed once on completion to avoid per-chunk re-parsing and the
                   flicker of half-rendered markdown. *@
                <span class="chat-streaming">@entry.Text</span>
            }
            else
            {
                <span class="chat-markdown">@RenderMarkdown(entry.Text)</span>
            }

            @if (!entry.IsUser && entry.Citations is { Count: > 0 })
            {
                var cites = entry.Citations
                    .GroupBy(c => (c.DocumentId, c.SectionTitle))
                    .Select(g => g.First())
                    .ToList();

                <div class="chat-citations">
                    <span class="chat-citations-label">Sources (ranked)</span>
                    <ol class="chat-citations-list">
                        @for (var i = 0; i < cites.Count; i++)
                        {
                            var cite = cites[i];
                            <li>
                                <span class="chat-citation-rank">@(i + 1))</span>
                                <a href="@($"documents/{cite.DocumentId}")">@cite.DocumentTitle</a>
                                @if (!string.IsNullOrWhiteSpace(cite.ClaimNumber))
                                {
                                    <span class="muted"> · Claim @cite.ClaimNumber</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(cite.SectionTitle))
                                {
                                    <span class="muted"> · @cite.SectionTitle</span>
                                }
                            </li>
                        }
                    </ol>
                </div>
            }
        </div>
    }
</div>

<div class="chat-input">
    <input @bind="_input" @bind:event="oninput" @onkeydown="OnKeyDown"
           placeholder="Ask a question..." disabled="@_busy" />
    <button @onclick="Send" disabled="@(_busy || string.IsNullOrWhiteSpace(_input))">Send</button>
</div>

@code {
    // Markdown rendering is constrained to safe inline/block formatting; DisableHtml() drops any
    // raw HTML the model might emit, so the streamed answer cannot inject markup.
    private static readonly MarkdownPipeline MarkdownPipeline =
        new MarkdownPipelineBuilder().DisableHtml().Build();

    private readonly List<Entry> _entries = new();
    private string _input = string.Empty;
    private bool _busy;

    private static MarkupString RenderMarkdown(string text) =>
        (MarkupString)Markdown.ToHtml(text ?? string.Empty, MarkdownPipeline);

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(_input) || _busy)
        {
            return;
        }

        _busy = true;
        var question = _input.Trim();
        _entries.Add(new Entry { IsUser = true, Text = question });
        _input = string.Empty;

        var answer = new Entry { IsUser = false, Text = string.Empty, IsStreaming = true };
        _entries.Add(answer);

        try
        {
            var result = await ChatService.AskAsync(question);
            answer.Citations = result.Citations;

            await foreach (var chunk in result.TextUpdates)
            {
                answer.Text += chunk;
                StateHasChanged();
            }

            if (string.IsNullOrEmpty(answer.Text))
            {
                answer.Text = "(The model returned no answer.)";
            }
        }
        catch (Exception ex)
        {
            answer.IsError = true;
            answer.Citations = null;
            answer.Text = $"Something went wrong calling the model: {ex.Message}";
        }
        finally
        {
            // Done streaming: the final render swaps raw text for parsed markdown.
            answer.IsStreaming = false;
            _busy = false;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Send();
        }
    }

    private sealed class Entry
    {
        public bool IsUser { get; init; }
        public string Text { get; set; } = string.Empty;
        public bool IsError { get; set; }
        public bool IsStreaming { get; set; }
        public IReadOnlyList<RetrievedPassage>? Citations { get; set; }
    }
}
