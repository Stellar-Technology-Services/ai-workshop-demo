@page "/documents"
@rendermode InteractiveServer
@using ClaimsChat.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ClaimsChatDbContext> DbFactory

<PageTitle>Documents — ClaimsChat</PageTitle>

<h1>Documents</h1>

@if (_documents is null)
{
    <p class="muted">Loading…</p>
}
else if (_documents.Count == 0)
{
    <p class="muted">
        No documents found. Add <code>.txt</code> files to
        <code>src/ClaimsChat/Documents/</code> and restart.
    </p>
}
else
{
    <p class="muted">
        @_documents.Count document(s) seeded from the Documents folder.
        <strong>In Retrieval</strong> controls whether the chat can ground answers in a
        document — the human checkpoint for what reaches the model.
    </p>
    <table class="doc-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Claim Number</th>
                <th>In Retrieval</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in _documents)
            {
                <tr>
                    <td><a href="@($"documents/{doc.Id}")">@doc.Title</a></td>
                    <td>@(doc.ClaimNumber ?? "—")</td>
                    <td>
                        <label class="retrieval-toggle">
                            <input type="checkbox"
                                   checked="@doc.IncludedInRetrieval"
                                   @onchange="e => ToggleRetrievalAsync(doc.Id, (bool)e.Value!)" />
                            <span class="badge @(doc.IncludedInRetrieval ? "included" : "excluded")">
                                @(doc.IncludedInRetrieval ? "Included" : "Excluded")
                            </span>
                        </label>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Document>? _documents;

    protected override async Task OnInitializedAsync()
    {
        await LoadDocumentsAsync();
    }

    private async Task LoadDocumentsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _documents = await db.Documents
            .OrderBy(d => d.Title)
            .ToListAsync();
    }

    // App-layer write: scope what data reaches the sealed box by toggling a
    // document's eligibility. A short-lived tracked context per unit of work,
    // matching how this page reads (IDbContextFactory, not a circuit-scoped context).
    private async Task ToggleRetrievalAsync(int documentId, bool included)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var doc = await db.Documents.FindAsync(documentId);
        if (doc is null)
        {
            return;
        }

        doc.IncludedInRetrieval = included;
        await db.SaveChangesAsync();
        await LoadDocumentsAsync();
    }
}
